function startListening() {
    const recognition = new (window.SpeechRecognition || window.webkitSpeechRecognition)();
    recognition.lang = "en-IN";

    recognition.start();

    recognition.onresult = function(event) {
        let text = event.results[0][0].transcript.toLowerCase();
        document.getElementById("voiceText").innerText = "You said: " + text;

        respond(text);
    };
}

function respond(command) {
    let response = "";

    if (command.includes("irrigation") || command.includes("water")) {
        response = "Smart irrigation system helps you control water usage efficiently.";
    } 
    else if (command.includes("crop") || command.includes("soil")) {
        response = "Based on soil type, crops like cotton or rice are recommended.";
    } 
    else if (command.includes("disease")) {
        response = "Upload plant image to detect diseases using AI.";
    } 
    else if (command.includes("weather")) {
        response = "Weather module shows temperature and conditions.";
    } 
    else if (command.includes("market")) {
        response = "Farmer market helps you sell crops directly to buyers.";
    } 
    else if (command.includes("hello")) {
        response = "Hello! Welcome to AgriSmart AI.";
    } 
    else {
        response = "Sorry, I did not understand. Please try again.";
    }

    speak(response);
}

function speak(message) {
    let msg = new SpeechSynthesisUtterance(message);
    msg.lang = "en-IN";
    speechSynthesis.speak(msg);
}